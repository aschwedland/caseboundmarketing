---
---

<section class="bg-casebound-wallpaper px-6 py-16 sm:py-24">
  <div class="max-w-3xl mx-auto">
    <h2 class="font-serif font-medium text-2xl sm:text-[32px] mb-6 leading-snug">
      Library and lists, finally separate
    </h2>

    <p class="text-base sm:text-[17px] leading-relaxed mb-12 max-w-2xl">
      Most book apps stack your shelves, your reading state, and your custom lists into one mess. When you own 500 books across 10 overlapping shelves, you can't cleanly answer "what do I actually own?" Casebound keeps your library &mdash; a real catalog with ownership, format, and reading status &mdash; separate from your lists, which are tags you can layer on top. A book lives in your library once, in zero or many lists, with one clean record.
    </p>

    <!-- Inline SVG diagram -->
    <div class="flex justify-center">
      <svg
        viewBox="0 0 520 200"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        class="w-full max-w-lg"
        role="img"
        aria-label="Diagram showing a single library entry connected to multiple list tags"
      >
        <!-- Library entry box -->
        <rect x="20" y="30" width="180" height="140" rx="8" fill="currentColor" fill-opacity="0.06" stroke="var(--color-casebound-green)" stroke-width="2" />
        <text x="110" y="58" text-anchor="middle" fill="var(--color-casebound-green)" font-size="13" font-weight="600" font-family="var(--font-family-serif)">Library entry</text>
        <line x1="40" y1="70" x2="180" y2="70" stroke="var(--color-casebound-border)" stroke-width="1" />

        <!-- Format rows -->
        <rect x="40" y="80" width="140" height="24" rx="4" fill="var(--color-casebound-green)" fill-opacity="0.1" />
        <text x="110" y="96" text-anchor="middle" fill="var(--color-casebound-text)" font-size="11" font-family="var(--font-family-sans)">Hardcover</text>

        <rect x="40" y="110" width="140" height="24" rx="4" fill="var(--color-casebound-green)" fill-opacity="0.1" />
        <text x="110" y="126" text-anchor="middle" fill="var(--color-casebound-text)" font-size="11" font-family="var(--font-family-sans)">Kindle</text>

        <rect x="40" y="140" width="140" height="24" rx="4" fill="var(--color-casebound-green)" fill-opacity="0.1" />
        <text x="110" y="156" text-anchor="middle" fill="var(--color-casebound-text)" font-size="11" font-family="var(--font-family-sans)">Audible</text>

        <!-- Arrows -->
        <line x1="210" y1="82" x2="310" y2="60" stroke="var(--color-casebound-gold)" stroke-width="2" marker-end="url(#arrowhead)" />
        <line x1="210" y1="100" x2="310" y2="100" stroke="var(--color-casebound-gold)" stroke-width="2" marker-end="url(#arrowhead)" />
        <line x1="210" y1="118" x2="310" y2="140" stroke="var(--color-casebound-gold)" stroke-width="2" marker-end="url(#arrowhead)" />

        <!-- List tags -->
        <rect x="320" y="40" width="160" height="32" rx="16" fill="var(--color-casebound-green)" fill-opacity="0.15" stroke="var(--color-casebound-green)" stroke-width="1.5" />
        <text x="400" y="61" text-anchor="middle" fill="var(--color-casebound-green)" font-size="12" font-family="var(--font-family-sans)">Favorites</text>

        <rect x="320" y="84" width="160" height="32" rx="16" fill="var(--color-casebound-green)" fill-opacity="0.15" stroke="var(--color-casebound-green)" stroke-width="1.5" />
        <text x="400" y="105" text-anchor="middle" fill="var(--color-casebound-green)" font-size="12" font-family="var(--font-family-sans)">Sci-fi</text>

        <rect x="320" y="128" width="160" height="32" rx="16" fill="var(--color-casebound-green)" fill-opacity="0.15" stroke="var(--color-casebound-green)" stroke-width="1.5" />
        <text x="400" y="149" text-anchor="middle" fill="var(--color-casebound-green)" font-size="12" font-family="var(--font-family-sans)">Gifts for mom</text>

        <!-- Labels -->
        <text x="110" y="195" text-anchor="middle" fill="var(--color-casebound-muted)" font-size="11" font-family="var(--font-family-sans)">One record</text>
        <text x="400" y="195" text-anchor="middle" fill="var(--color-casebound-muted)" font-size="11" font-family="var(--font-family-sans)">Zero or many tags</text>

        <!-- Arrowhead marker -->
        <defs>
          <marker id="arrowhead" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
            <polygon points="0 0, 8 3, 0 6" fill="var(--color-casebound-gold)" />
          </marker>
        </defs>
      </svg>
    </div>
  </div>
</section>
