---
---

<section class="bg-casebound-wallpaper px-6 py-16 sm:py-24">
  <div class="max-w-4xl mx-auto">
    <h2 class="font-serif font-medium text-2xl sm:text-[32px] mb-10 leading-snug">
      Built for serious readers
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Built for -->
      <div class="bg-casebound-green/5 border border-casebound-green/20 rounded-xl p-6 sm:p-8">
        <h3 class="font-serif font-medium text-lg mb-4 text-casebound-green">Built for</h3>
        <ul class="space-y-3 text-[15px] sm:text-base leading-relaxed">
          <li class="flex gap-3">
            <span class="text-casebound-green shrink-0 mt-0.5" aria-hidden="true">&#10003;</span>
            <span>Readers with substantial libraries &mdash; often 100 books or more.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-casebound-green shrink-0 mt-0.5" aria-hidden="true">&#10003;</span>
            <span>People who care about being a good steward of what they own.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-casebound-green shrink-0 mt-0.5" aria-hidden="true">&#10003;</span>
            <span>Anyone who wants meaningful reading data without performance theater.</span>
          </li>
        </ul>
      </div>

      <!-- Not built for -->
      <div class="bg-casebound-paper border border-casebound-border rounded-xl p-6 sm:p-8">
        <h3 class="font-serif font-medium text-lg mb-4 text-casebound-muted">Not built for</h3>
        <ul class="space-y-3 text-[15px] sm:text-base leading-relaxed text-casebound-muted">
          <li class="flex gap-3">
            <span class="shrink-0 mt-0.5" aria-hidden="true">&#10007;</span>
            <span>Casual readers chasing yearly book-count goals.</span>
          </li>
          <li class="flex gap-3">
            <span class="shrink-0 mt-0.5" aria-hidden="true">&#10007;</span>
            <span>Review writers chasing social validation.</span>
          </li>
          <li class="flex gap-3">
            <span class="shrink-0 mt-0.5" aria-hidden="true">&#10007;</span>
            <span>People who want algorithmic recommendations to tell them what to read next.</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
