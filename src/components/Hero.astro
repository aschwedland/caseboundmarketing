<section class="bg-casebound-paper px-6 pt-16 pb-20 sm:pt-24 sm:pb-28">
  <div class="max-w-2xl mx-auto text-center">
    <!-- App icon -->
    <img
      src="/icon.png"
      width="112"
      height="112"
      alt="Casebound app icon"
      class="mx-auto mb-8 rounded-[22%]"
    />

    <!-- Wordmark -->
    <h1 class="font-serif font-semibold text-5xl sm:text-[56px] mb-4 leading-tight">
      Casebound
    </h1>

    <!-- Tagline -->
    <p class="font-serif font-medium text-xl sm:text-2xl text-casebound-muted mb-6">
      Track what you read. Catalog what you own.
    </p>

    <!-- Sub-description -->
    <p class="text-base sm:text-[17px] text-casebound-text max-w-lg mx-auto mb-10 leading-relaxed">
      A book tracker built for serious readers and library builders. Two things, done properly: real reading data, and a real catalog of what's on your shelf.
    </p>

    <!-- CTA -->
    <!-- EMAIL CAPTURE: Replace this mailto with a real form or ConvertKit embed
         when launch email collection is ready. The mailto is intentionally simple
         for the pre-launch period. -->
    <a
      href="mailto:support@pixel-master.com?subject=Casebound%20launch%20notify&body=Notify%20me%20when%20Casebound%20is%20ready"
      class="inline-block bg-casebound-green text-casebound-paper px-8 py-3.5 rounded-lg font-medium text-lg hover:opacity-90 transition-opacity"
    >
      Notify me when it's ready
    </a>

    <!-- Platform note -->
    <p class="text-sm text-casebound-muted mt-4">
      Coming to iOS and Android.
    </p>
  </div>
</section>
